#!/usr/bin/env python3
"""mncli — lightweight CLI for interacting with a running marimo notebook.

Thin wrapper over the marimo kernel HTTP API (via execute-code.sh) that
exposes stable verbs (start/status/create/edit/run/delete/install/exec) with
clean JSON output. Code for create/edit is passed via base64 to dodge all
shell-escaping nightmares.
"""

from __future__ import annotations

import argparse
import base64
import json
import os
import re
import shlex
import shutil
import subprocess
import sys
import time
import urllib.error
import urllib.request
from pathlib import Path

try:
    import tomllib
except ModuleNotFoundError:  # pragma: no cover - Python < 3.11 fallback
    tomllib = None

# marimo's scratchpad renders the final expression's value as HTML into the
# done-event output, which `execute-code.sh` concatenates onto stdout. Strip
# the specific wrapper so exec --json yields clean stdout for agents. Only
# the text-xs <pre> wrapper is stripped — richer HTML is preserved.
_MARIMO_TEXT_XS_PRE = re.compile(r"<pre class='text-xs'>.*?</pre>\n?", re.DOTALL)
__version__ = "0.1.2"


def _strip_marimo_render(text: str) -> str:
    return _MARIMO_TEXT_XS_PRE.sub("", text)


def _default_execute_script() -> Path:
    installed = shutil.which("mncli-execute-code")
    if installed:
        return Path(installed)
    sibling = Path(__file__).resolve().with_name("mncli-execute-code")
    if sibling.exists():
        return sibling
    return Path.home() / ".claude/skills/marimo-pair/scripts/execute-code.sh"


DEFAULT_EXECUTE_SCRIPT = _default_execute_script()
EXECUTE_SCRIPT = Path(os.environ.get("MNCLI_EXECUTE_SCRIPT", str(DEFAULT_EXECUTE_SCRIPT)))


_TRANSPORT_FAILURE_MARKERS = (
    "No running marimo instances found",
    "Failed to connect to marimo server",
    "No active sessions on the server",
    "Multiple instances found",
    "Multiple sessions on server",
)


def _is_transport_failure(stderr: str) -> bool:
    return any(m in stderr for m in _TRANSPORT_FAILURE_MARKERS)


def _transport_failure_kind(stderr: str) -> str:
    if "No running marimo instances found" in stderr:
        return "no_instances"
    if "Failed to connect" in stderr:
        return "failed_connect"
    if "No active sessions" in stderr:
        return "no_active_sessions"
    if "Multiple instances found" in stderr:
        return "multiple_instances"
    if "Multiple sessions on server" in stderr:
        return "multiple_sessions"
    return "transport_error"


def _transport_failure_hint(kind: str) -> str:
    if kind == "no_instances":
        return "Start a notebook with `mncli start <file.py> --json`, or pass --url for a running server."
    if kind == "failed_connect":
        return "The server URL is unreachable. Check the port or run without --url to auto-discover a local server."
    if kind == "no_active_sessions":
        return "The server is up but no notebook session is active. If you used --headless, open the registered URL before status/create/edit/exec."
    if kind == "multiple_instances":
        return "Pass --port, or choose a port from `mncli servers --json`."
    if kind == "multiple_sessions":
        return "Pass --session with the intended session id."
    return "Check the marimo server and transport flags."


def _transport_failure_payload(
    stderr: str,
    *,
    stdout: str = "",
    exit_code: int = 1,
) -> dict:
    kind = _transport_failure_kind(stderr)
    lines = [line.strip() for line in stderr.splitlines() if line.strip()]
    payload = {
        "ok": False,
        "exit_code": exit_code or 1,
        "transport_error": True,
        "kind": kind,
        "message": lines[0] if lines else kind,
        "hint": _transport_failure_hint(kind),
        "stderr": stderr,
    }
    if stdout:
        payload["stdout"] = _strip_marimo_render(stdout)
    if kind == "multiple_instances":
        ports = []
        for line in lines[1:]:
            match = re.search(r":(\d+)(?:\b|$)", line)
            if match:
                ports.append(match.group(1))
        if ports:
            payload["ports"] = ports
    elif kind == "multiple_sessions":
        sessions = []
        for line in lines[1:]:
            parts = line.split(maxsplit=1)
            if parts:
                sessions.append({"id": parts[0], "filename": parts[1] if len(parts) > 1 else ""})
        if sessions:
            payload["sessions"] = sessions
    return payload


def _print_transport_hint(stderr: str) -> None:
    sys.stderr.write(stderr if stderr.endswith("\n") else stderr + "\n")
    kind = _transport_failure_kind(stderr)
    if kind == "no_instances":
        sys.stderr.write(
            "hint: start a notebook with:\n"
            "        mncli start <file.py>\n"
            "      or point at a running server with --url http://host:port\n"
        )
    elif kind == "failed_connect":
        sys.stderr.write(
            "hint: the URL is unreachable. check the port, or run\n"
            "        `mncli` with no --url to auto-discover a local server.\n"
        )
    elif kind == "no_active_sessions":
        sys.stderr.write(
            "hint: the server is up but no notebook session is active. If you used\n"
            "      `mncli start --headless`, open the registered URL in a browser before\n"
            "      running status/create/edit/exec.\n"
        )
    elif kind in {"multiple_instances", "multiple_sessions"}:
        sys.stderr.write(
            "hint: use --port or --session to disambiguate.\n"
        )


def _run_kernel(code: str, extra_args: list[str]) -> tuple[str, str, int]:
    if not EXECUTE_SCRIPT.exists():
        sys.stderr.write(
            f"error: execute transport not found at {EXECUTE_SCRIPT}\n"
            "       set MNCLI_EXECUTE_SCRIPT to override\n"
        )
        sys.exit(2)
    cmd = [str(EXECUTE_SCRIPT), *extra_args]
    result = subprocess.run(cmd, input=code, capture_output=True, text=True)
    return result.stdout, result.stderr, result.returncode


def _indent(text: str, prefix: str) -> str:
    return "\n".join(prefix + line if line else line for line in text.splitlines())


def _wrap_snippet(body: str) -> str:
    return (
        "import json as _mncli_json, traceback as _mncli_tb\n"
        "import marimo._code_mode as _mncli_cm\n"
        "\n"
        "try:\n"
        + _indent(body, "    ")
        + "\n"
        "except Exception as _mncli_exc:\n"
        "    print(_mncli_json.dumps({\n"
        '        "ok": False,\n'
        '        "error": str(_mncli_exc),\n'
        '        "type": type(_mncli_exc).__name__,\n'
        '        "traceback": _mncli_tb.format_exc(),\n'
        "    }))\n"
    )


def _exec_json(body: str, extra_args: list[str], *, json_errors: bool = False) -> dict:
    code = _wrap_snippet(body)
    stdout, stderr, rc = _run_kernel(code, extra_args)
    if _is_transport_failure(stderr):
        if json_errors:
            print(json.dumps(_transport_failure_payload(stderr, stdout=stdout, exit_code=rc or 1), ensure_ascii=False))
            sys.exit(rc or 1)
        _print_transport_hint(stderr)
        sys.exit(1)
    lines = [l for l in stdout.splitlines() if l.strip()]
    if not lines:
        if stderr:
            sys.stderr.write(stderr)
        sys.stderr.write("error: no output from kernel\n")
        sys.exit(rc or 1)
    try:
        data = json.loads(lines[-1])
    except json.JSONDecodeError:
        sys.stderr.write(f"error: could not parse kernel output as JSON:\n{stdout}\n")
        if stderr:
            sys.stderr.write(stderr)
        sys.exit(1)
    if not data.get("ok"):
        sys.stderr.write(
            f"error: {data.get('type', 'Error')}: {data.get('error', 'unknown')}\n"
        )
        tb = data.get("traceback", "")
        if tb:
            sys.stderr.write(tb)
            if not tb.endswith("\n"):
                sys.stderr.write("\n")
        sys.exit(1)
    return data


def _read_code(inline: str | None, source: str | None) -> str:
    if inline is not None:
        return inline
    if source is None or source == "-":
        if sys.stdin.isatty():
            sys.stderr.write("error: no code provided (use --code, a file path, or pipe stdin)\n")
            sys.exit(2)
        return sys.stdin.read()
    path_str = source[1:] if source.startswith("@") else source
    return Path(path_str).read_text()


def _encode(code: str) -> str:
    return base64.b64encode(code.encode("utf-8")).decode("ascii")


def _has_exact_tag_marker(code: str, marker: str) -> bool:
    return code.split("\n", 1)[0] == marker


def _transport_args(args: argparse.Namespace) -> list[str]:
    extra: list[str] = []
    if args.port:
        extra += ["--port", args.port]
    if args.url:
        extra += ["--url", args.url]
    if args.session:
        extra += ["--session", args.session]
    if args.token:
        extra += ["--token", args.token]
    return extra


def _marimo_servers_dir() -> Path:
    ostype = os.environ.get("OSTYPE", "")
    if ostype.startswith(("msys", "cygwin")):
        return Path.home() / ".marimo/servers"
    state_home = Path(os.environ.get("XDG_STATE_HOME", str(Path.home() / ".local/state")))
    return state_home / "marimo/servers"


def _mncli_servers_dir() -> Path:
    state_home = Path(os.environ.get("XDG_STATE_HOME", str(Path.home() / ".local/state")))
    return state_home / "mncli" / "servers"


def _pid_is_live(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    except OSError:
        return False


def _discover_servers(*, cleanup: bool = True) -> tuple[list[dict], Path]:
    servers_dir = _marimo_servers_dir()
    if not servers_dir.is_dir():
        return [], servers_dir

    servers: list[dict] = []
    for path in servers_dir.glob("*.json"):
        try:
            entry = json.loads(path.read_text())
            pid = int(entry["pid"])
        except (OSError, ValueError, KeyError, json.JSONDecodeError):
            continue

        if not _pid_is_live(pid):
            if cleanup:
                try:
                    path.unlink()
                except OSError:
                    pass
            continue
        servers.append(entry)

    servers.sort(key=lambda e: (str(e.get("host", "")), int(e.get("port") or 0)))
    return servers, servers_dir


def _server_registry_key(server: dict) -> str:
    server_id = server.get("server_id")
    if server_id:
        return f"id:{server_id}"
    return "pid:{pid}|host:{host}|port:{port}|base:{base_url}".format(
        pid=server.get("pid"),
        host=server.get("host"),
        port=server.get("port"),
        base_url=server.get("base_url"),
    )


def _server_state_path(server: dict) -> Path:
    safe_key = re.sub(r"[^A-Za-z0-9_.-]+", "_", _server_registry_key(server))
    return _mncli_servers_dir() / f"{safe_key}.json"


def _normalize_notebook_path(notebook: Path | str) -> str:
    return str(Path(notebook).expanduser().resolve())


def _write_server_state(
    server: dict,
    *,
    notebook: Path,
    log_path: Path,
    runner: str,
    command: list[str],
) -> None:
    payload = {
        "server_id": server.get("server_id"),
        "pid": server.get("pid"),
        "host": server.get("host"),
        "port": server.get("port"),
        "base_url": server.get("base_url"),
        "notebook": str(notebook),
        "notebook_abs": _normalize_notebook_path(notebook),
        "log": str(log_path),
        "runner": runner,
        "command": command,
        "updated_at": time.time(),
    }
    path = _server_state_path(server)
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n")
    except OSError:
        pass


def _read_server_state(server: dict) -> dict | None:
    try:
        payload = json.loads(_server_state_path(server).read_text())
    except (OSError, json.JSONDecodeError):
        return None
    if payload.get("pid") != server.get("pid"):
        return None
    return payload


def _read_process_command(pid: int | str | None) -> str:
    if pid is None:
        return ""
    try:
        completed = subprocess.run(
            ["ps", "-p", str(pid), "-o", "command="],
            check=False,
            capture_output=True,
            text=True,
        )
    except OSError:
        return ""
    if completed.returncode != 0:
        return ""
    return completed.stdout.strip()


def _server_matches_notebook(server: dict, notebook: Path) -> bool:
    target = _normalize_notebook_path(notebook)
    state = _read_server_state(server)
    if state is not None and state.get("notebook_abs") == target:
        return True

    command = _read_process_command(server.get("pid"))
    if not command:
        return False
    try:
        tokens = shlex.split(command)
    except ValueError:
        tokens = command.split()
    candidates = {str(notebook), target}
    for token in tokens:
        if token in candidates:
            return True
    return False


def _find_reusable_server(
    servers: list[dict],
    *,
    notebook: Path,
    port: str | None,
) -> dict | None:
    for server in servers:
        if port is not None and str(server.get("port")) != str(port):
            continue
        if _server_matches_notebook(server, notebook):
            return server
    return None


def _find_server_on_port(servers: list[dict], port: str | None) -> dict | None:
    if port is None:
        return None
    for server in servers:
        if str(server.get("port")) == str(port):
            return server
    return None


def _find_new_registered_server(
    servers: list[dict],
    *,
    previous_keys: set[str],
    port: str | None,
) -> dict | None:
    for server in servers:
        if port is not None and str(server.get("port")) != str(port):
            continue
        if _server_registry_key(server) not in previous_keys:
            return server
    return None


def _server_url(server: dict) -> str:
    host = str(server.get("host") or "127.0.0.1")
    if host == "0.0.0.0":
        host = "127.0.0.1"
    if ":" in host and not host.startswith("["):
        host = f"[{host}]"
    base_url = server.get("base_url") or ""
    return f"http://{host}:{server.get('port')}{base_url}"


def _read_server_session_ids(
    server: dict,
    *,
    timeout_seconds: float = 1.0,
) -> tuple[list[str] | None, str | None]:
    try:
        with urllib.request.urlopen(
            f"{_server_url(server)}/api/sessions",
            timeout=timeout_seconds,
        ) as response:
            payload = json.loads(response.read().decode("utf-8"))
    except (OSError, urllib.error.URLError, ValueError) as exc:
        return None, str(exc)

    if not isinstance(payload, dict):
        return None, "unexpected /api/sessions response"
    return sorted(str(session_id) for session_id in payload), None


def _wait_for_server_session_ids(
    server: dict,
    *,
    timeout_seconds: float,
    poll_interval_seconds: float = 0.25,
) -> tuple[list[str] | None, str | None]:
    deadline = time.monotonic() + max(timeout_seconds, 0.0)
    last_ids: list[str] | None = None
    last_error: str | None = None
    while True:
        last_ids, last_error = _read_server_session_ids(server)
        if last_ids:
            return last_ids, last_error
        remaining = deadline - time.monotonic()
        if remaining <= 0:
            return last_ids, last_error
        time.sleep(min(poll_interval_seconds, remaining))


def _next_step_for_start(
    *,
    server: dict | None,
    session_ids: list[str] | None,
    session_error: str | None,
    args: argparse.Namespace,
) -> str:
    if server is None:
        return "check the log and retry"
    port = str(server.get("port"))
    if session_ids is None:
        return "check the server URL in a browser, then run mncli status"
    if not session_ids:
        return f"open {_server_url(server)}, then run mncli --port {port} status"
    if len(session_ids) == 1:
        return f"mncli --port {port} status"
    return "use --session with status/create/edit/run/delete/install/exec"


def _add_start_session_state(
    payload: dict,
    *,
    server: dict | None,
    session_ids: list[str] | None,
    session_error: str | None,
    args: argparse.Namespace,
) -> None:
    payload["session_ids"] = session_ids
    payload["session_error"] = session_error
    payload["ready_for_cells"] = bool(session_ids) and len(session_ids) == 1
    payload["next"] = _next_step_for_start(
        server=server,
        session_ids=session_ids,
        session_error=session_error,
        args=args,
    )


def _wait_for_server_registration(
    proc: subprocess.Popen,
    *,
    previous_keys: set[str],
    port: str | None,
    timeout_seconds: float,
) -> tuple[dict | None, Path, int | None]:
    deadline = time.monotonic() + max(timeout_seconds, 0.0)
    servers_dir = _marimo_servers_dir()
    while True:
        servers, servers_dir = _discover_servers(cleanup=True)
        server = _find_new_registered_server(servers, previous_keys=previous_keys, port=port)
        if server is not None:
            return server, servers_dir, None

        rc = proc.poll()
        if rc is not None:
            return None, servers_dir, rc

        remaining = deadline - time.monotonic()
        if remaining <= 0:
            return None, servers_dir, None
        time.sleep(min(0.1, remaining))


def _dependency_name(spec: str) -> str:
    return re.split(r"[\s<>=!~;\[]", spec, 1)[0].lower()


def _find_pyproject(start: Path) -> Path | None:
    current = start.resolve() if start.exists() else start.absolute()
    if current.is_file() or current.suffix:
        current = current.parent
    for parent in (current, *current.parents):
        candidate = parent / "pyproject.toml"
        if candidate.exists():
            return candidate
    return None


def _pyproject_has_marimo(pyproject: Path) -> bool:
    if tomllib is None:
        try:
            text = pyproject.read_text()
        except OSError:
            return False
        fallback_pattern = r"(?im)^\s*marimo\b|['\"]marimo(?:[<>=!~;\[]|['\"])"
        return re.search(fallback_pattern, text) is not None

    try:
        data = tomllib.loads(pyproject.read_text())
    except OSError:
        return False
    except tomllib.TOMLDecodeError:
        return False

    project = data.get("project", {})
    deps = list(project.get("dependencies", []))
    for group in project.get("optional-dependencies", {}).values():
        if isinstance(group, list):
            deps.extend(group)
    for group in data.get("dependency-groups", {}).values():
        if isinstance(group, list):
            deps.extend(group)
    if any(isinstance(dep, str) and _dependency_name(dep) == "marimo" for dep in deps):
        return True

    pixi_deps = data.get("tool", {}).get("pixi", {}).get("dependencies", {})
    if isinstance(pixi_deps, dict) and "marimo" in pixi_deps:
        return True
    if isinstance(pixi_deps, list):
        return any(
            isinstance(dep, str) and _dependency_name(dep) == "marimo"
            for dep in pixi_deps
        )
    return False


def _pyproject_has_pixi_marimo(pyproject: Path) -> bool:
    if tomllib is None:
        return False

    try:
        data = tomllib.loads(pyproject.read_text())
    except (OSError, tomllib.TOMLDecodeError):
        return False

    pixi_deps = data.get("tool", {}).get("pixi", {}).get("dependencies", {})
    if isinstance(pixi_deps, dict):
        return "marimo" in pixi_deps
    if isinstance(pixi_deps, list):
        return any(
            isinstance(dep, str) and _dependency_name(dep) == "marimo"
            for dep in pixi_deps
        )
    return False


def _notebook_uses_project_marimo(notebook: Path) -> bool:
    pyproject = _find_pyproject(notebook)
    return pyproject is not None and _pyproject_has_marimo(pyproject)


def _notebook_uses_pixi_marimo(notebook: Path) -> bool:
    pyproject = _find_pyproject(notebook)
    return pyproject is not None and _pyproject_has_pixi_marimo(pyproject)


def _resolve_start_runner(runner: str, notebook: Path) -> str:
    if runner != "auto":
        if shutil.which(runner) is None:
            sys.stderr.write(f"error: {runner!r} not found on PATH\n")
            sys.exit(2)
        return runner

    if _notebook_uses_pixi_marimo(notebook) and shutil.which("pixi"):
        return "pixi"
    if _notebook_uses_project_marimo(notebook) and shutil.which("uv"):
        return "uv"
    if shutil.which("uvx"):
        return "uvx"
    if shutil.which("marimo"):
        return "marimo"

    sys.stderr.write(
        "error: could not find uvx or marimo on PATH\n"
        "hint: install uv, or pass --runner marimo if marimo is installed elsewhere\n"
    )
    sys.exit(2)


def _default_start_log(notebook: Path) -> Path:
    return notebook.with_suffix(".marimo.log")


def _build_start_command(args: argparse.Namespace) -> tuple[list[str], Path, Path, str]:
    notebook = Path(args.notebook).expanduser()
    runner = _resolve_start_runner(args.runner, notebook)
    if args.log:
        log_path = Path(args.log).expanduser()
    else:
        log_path = _default_start_log(notebook)

    if runner == "uv":
        cmd = ["uv", "run", "marimo", "edit", str(notebook)]
    elif runner == "uvx":
        cmd = ["uvx", "marimo@latest", "edit", str(notebook)]
    elif runner == "pixi":
        cmd = ["pixi", "run", "marimo", "edit", str(notebook)]
    else:
        cmd = ["marimo", "edit", str(notebook)]

    cmd.append("--no-token")
    if args.port:
        cmd.extend(["--port", str(args.port)])
    if args.headless:
        cmd.append("--headless")
    if args.mcp:
        cmd.append("--mcp")

    sandbox = args.sandbox
    if sandbox is None:
        sandbox = runner not in {"uv", "pixi"}
    if sandbox:
        cmd.append("--sandbox")

    return cmd, log_path, notebook, runner


def _format_command(cmd: list[str]) -> str:
    return " ".join(shlex.quote(part) for part in cmd)


def _format_elapsed(seconds: float) -> str:
    if seconds < 10:
        return f"{seconds:.2f}s"
    if seconds < 60:
        return f"{seconds:.1f}s"
    minutes, remainder = divmod(seconds, 60)
    return f"{int(minutes)}m{remainder:04.1f}s"


def _tail_text(path: Path, limit: int = 4000) -> str:
    try:
        with path.open("rb") as f:
            f.seek(0, os.SEEK_END)
            size = f.tell()
            f.seek(max(size - limit, 0))
            return f.read().decode("utf-8", errors="replace")
    except OSError:
        return ""


# --- commands ---------------------------------------------------------------


def cmd_servers(args: argparse.Namespace) -> None:
    servers, servers_dir = _discover_servers(cleanup=not args.no_cleanup)
    if args.port:
        servers = [s for s in servers if str(s.get("port")) == str(args.port)]

    if args.json:
        print(json.dumps({"ok": True, "registry": str(servers_dir), "servers": servers}, ensure_ascii=False))
        return

    if not servers:
        print(f"(no running marimo instances; registry: {servers_dir})")
        return

    for server in servers:
        host = server.get("host", "?")
        port = server.get("port", "?")
        base_url = server.get("base_url") or ""
        pid = server.get("pid", "?")
        server_id = server.get("server_id") or ""
        print(f"{host}:{port}{base_url}  pid={pid}" + (f"  id={server_id}" if server_id else ""))


def _print_start_summary(payload: dict, args: argparse.Namespace) -> None:
    if payload.get("reused"):
        print(f"reusing marimo pid {payload.get('pid')}")
    else:
        print(f"started marimo pid {payload.get('pid')}")
    print(f"notebook: {payload['notebook']}")
    print(f"log: {payload['log']}")
    server = payload.get("server") or {}
    server_pid = server.get("pid")
    server_pid_suffix = f"  pid={server_pid}" if server_pid is not None else ""
    print(f"registered: {payload['server_url']}{server_pid_suffix}")
    print(f"ready_for_cells: {str(bool(payload.get('ready_for_cells'))).lower()}")
    print(f"command: {_format_command(payload['command'])}")

    session_ids = payload.get("session_ids")
    session_error = payload.get("session_error")
    if session_ids is None:
        print(f"session check: failed ({session_error})")
    elif not session_ids:
        print("sessions: none")
        print(f"open: {payload['server_url']}")
    elif len(session_ids) == 1:
        print(f"session: {session_ids[0]}")
    else:
        print(f"sessions: {len(session_ids)} active")
    print(f"next: {payload.get('next')}")


def _emit_start_payload(payload: dict, args: argparse.Namespace, *, exit_code: int = 0) -> None:
    if args.json:
        print(json.dumps(payload, ensure_ascii=False))
    else:
        _print_start_summary(payload, args)
    if exit_code:
        sys.exit(exit_code)


def _fail_start(message: str, payload: dict, args: argparse.Namespace, *, exit_code: int = 1) -> None:
    payload["ok"] = False
    payload["error"] = message
    if args.json:
        print(json.dumps(payload, ensure_ascii=False))
    else:
        sys.stderr.write(f"error: {message}\n")
        if payload.get("server_url"):
            sys.stderr.write(f"server: {payload['server_url']}\n")
        if payload.get("next"):
            sys.stderr.write(f"next: {payload['next']}\n")
    sys.exit(exit_code)


def cmd_start(args: argparse.Namespace) -> None:
    if args.url or args.session or args.token:
        sys.stderr.write("error: start accepts --port, but not --url, --session, or --token\n")
        sys.exit(2)

    cmd, log_path, notebook, runner = _build_start_command(args)
    servers_dir = _marimo_servers_dir()
    payload = {
        "ok": True,
        "dry_run": bool(args.dry_run),
        "headless": bool(args.headless),
        "reused": False,
        "pid": None,
        "notebook": str(notebook),
        "log": str(log_path),
        "registry": str(servers_dir),
        "server": None,
        "server_url": None,
        "session_ids": None,
        "session_error": None,
        "ready_for_cells": False,
        "next": None,
        "runner": runner,
        "command": cmd,
    }

    if args.dry_run:
        if args.json:
            print(json.dumps(payload, ensure_ascii=False))
        else:
            print(_format_command(cmd))
        return

    existing_servers, servers_dir = _discover_servers(cleanup=True)
    existing_server_keys = {_server_registry_key(server) for server in existing_servers}
    payload["registry"] = str(servers_dir)

    reuse = bool(getattr(args, "reuse", True)) and not bool(getattr(args, "force_new", False))
    existing_on_port = _find_server_on_port(existing_servers, args.port)
    reusable_server = _find_reusable_server(existing_servers, notebook=notebook, port=args.port)
    if reusable_server is not None and reuse:
        reusable_state = _read_server_state(reusable_server) or {}
        payload["reused"] = True
        payload["pid"] = reusable_server.get("pid")
        payload["notebook"] = reusable_state.get("notebook", payload["notebook"])
        payload["log"] = reusable_state.get("log", payload["log"])
        payload["runner"] = reusable_state.get("runner", payload["runner"])
        payload["command"] = reusable_state.get("command", payload["command"])
        payload["server"] = reusable_server
        payload["server_url"] = _server_url(reusable_server)
        if getattr(args, "wait_session", False):
            session_ids, session_error = _wait_for_server_session_ids(
                reusable_server,
                timeout_seconds=float(getattr(args, "session_timeout_seconds", 15.0)),
            )
        else:
            session_ids, session_error = _read_server_session_ids(reusable_server)
        _add_start_session_state(
            payload,
            server=reusable_server,
            session_ids=session_ids,
            session_error=session_error,
            args=args,
        )
        if getattr(args, "wait_session", False) and not payload["ready_for_cells"]:
            _fail_start("no active notebook session before --wait-session timeout", payload, args)
        _emit_start_payload(payload, args)
        return
    if existing_on_port is not None:
        payload["server"] = existing_on_port
        payload["server_url"] = _server_url(existing_on_port)
        _add_start_session_state(
            payload,
            server=existing_on_port,
            session_ids=None,
            session_error="port already has a running marimo server",
            args=args,
        )
        _fail_start(
            f"port {args.port} already has a running marimo server; use that port or choose another",
            payload,
            args,
            exit_code=2,
        )

    try:
        log_path.parent.mkdir(parents=True, exist_ok=True)
        with log_path.open("ab") as log_file:
            proc = subprocess.Popen(
                cmd,
                stdin=subprocess.DEVNULL,
                stdout=log_file,
                stderr=subprocess.STDOUT,
                start_new_session=True,
            )
    except OSError as exc:
        sys.stderr.write(f"error: failed to start marimo: {exc}\n")
        sys.exit(1)

    startup_check_seconds = max(float(getattr(args, "startup_check_seconds", 0.25)), 0.0)
    time.sleep(startup_check_seconds)
    rc = proc.poll()
    if rc is not None:
        sys.stderr.write(f"error: marimo exited immediately with code {rc}\n")
        sys.stderr.write(f"log: {log_path}\n")
        tail = _tail_text(log_path)
        if tail:
            sys.stderr.write("\nlast log output:\n")
            sys.stderr.write(tail if tail.endswith("\n") else tail + "\n")
        sys.exit(rc or 1)

    registration_timeout_seconds = max(
        float(getattr(args, "registration_timeout_seconds", 15.0)),
        0.0,
    )
    server, servers_dir, rc = _wait_for_server_registration(
        proc,
        previous_keys=existing_server_keys,
        port=args.port,
        timeout_seconds=registration_timeout_seconds,
    )
    payload["registry"] = str(servers_dir)
    if rc is not None:
        sys.stderr.write(f"error: marimo exited before registering with code {rc}\n")
        sys.stderr.write(f"log: {log_path}\n")
        tail = _tail_text(log_path)
        if tail:
            sys.stderr.write("\nlast log output:\n")
            sys.stderr.write(tail if tail.endswith("\n") else tail + "\n")
        sys.exit(rc or 1)
    if server is None:
        sys.stderr.write(
            f"error: marimo pid {proc.pid} did not register within "
            f"{registration_timeout_seconds:g}s\n"
        )
        sys.stderr.write(f"registry: {servers_dir}\n")
        sys.stderr.write(f"log: {log_path}\n")
        tail = _tail_text(log_path)
        if tail:
            sys.stderr.write("\nlast log output:\n")
            sys.stderr.write(tail if tail.endswith("\n") else tail + "\n")
        sys.exit(1)

    payload["pid"] = proc.pid
    payload["server"] = server
    payload["server_url"] = _server_url(server)
    _write_server_state(server, notebook=notebook, log_path=log_path, runner=runner, command=cmd)
    if getattr(args, "wait_session", False):
        session_ids, session_error = _wait_for_server_session_ids(
            server,
            timeout_seconds=float(getattr(args, "session_timeout_seconds", 15.0)),
        )
    else:
        session_ids, session_error = _read_server_session_ids(server)
    _add_start_session_state(
        payload,
        server=server,
        session_ids=session_ids,
        session_error=session_error,
        args=args,
    )
    if getattr(args, "wait_session", False) and not payload["ready_for_cells"]:
        _fail_start("no active notebook session before --wait-session timeout", payload, args)
    _emit_start_payload(payload, args)


STATUS_BODY = r'''
async with _mncli_cm.get_context() as _ctx:
    _cells = []
    for _c in _ctx.cells:
        _errs = []
        try:
            for _e in (_c.errors or []):
                _errs.append(str(_e))
        except Exception:
            pass
        _preview = (_c.code.split("\n", 1)[0] if _c.code else "").strip()[:80]
        _cells.append({
            "id": _c.id,
            "name": _c.name,
            "status": str(_c.status),
            "has_error": bool(_errs),
            "errors": _errs,
            "code_preview": _preview,
            "code_lines": (_c.code.count("\n") + 1) if _c.code else 0,
        })
print(_mncli_json.dumps({"ok": True, "cells": _cells}))
'''


def cmd_status(args: argparse.Namespace) -> None:
    data = _exec_json(STATUS_BODY, _transport_args(args), json_errors=args.json)
    cells = data["cells"]
    total = len(cells)
    err_total = sum(1 for c in cells if c["has_error"])
    if args.errors_only:
        cells = [c for c in cells if c["has_error"]]
    if args.json:
        print(json.dumps(cells, indent=2, ensure_ascii=False))
        return
    if not cells:
        if args.errors_only:
            print(f"(no errored cells; {total} cell(s) total)")
        else:
            print("(no cells)")
        return
    for c in cells:
        marker = "x" if c["has_error"] else "·"
        preview = c["code_preview"] or "(empty)"
        print(f"  {marker} {c['id']}  {c['status']:<10s}  {preview}")
        for e in c["errors"]:
            for line in e.splitlines():
                print(f"      ! {line}")
    if args.errors_only:
        print(f"\n{len(cells)} errored cell(s) (of {total} total)")
    else:
        print(f"\n{total} cell(s), {err_total} with errors")


