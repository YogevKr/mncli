def _run_body(targets_repr: str) -> str:
    return (
        f"_targets_input = {targets_repr}\n"
        "async with _mncli_cm.get_context() as _ctx:\n"
        '    if _targets_input == "__ALL__":\n'
        "        _targets = [_c.id for _c in _ctx.cells]\n"
        "    else:\n"
        "        _targets = _targets_input\n"
        "    for _t in _targets:\n"
        "        _ctx.run_cell(_t)\n"
        "\n"
        + _POST_RUN_SNIPPET
        + '\nprint(_mncli_json.dumps({"ok": True, "ran": _targets, "results": _post_results}))\n'
    )


_RESOLVE_ALL_BODY = (
    "async with _mncli_cm.get_context() as _ctx:\n"
    "    _ids = [_c.id for _c in _ctx.cells]\n"
    'print(_mncli_json.dumps({"ok": True, "ids": _ids}))\n'
)


_RUN_ONE_BODY_TEMPLATE = (
    "_targets = [__CID__]\n"
    "async with _mncli_cm.get_context() as _ctx:\n"
    "    _ctx.run_cell(__CID__)\n"
    + _POST_RUN_SNIPPET
    + 'print(_mncli_json.dumps({"ok": True, "ran": _targets, "results": _post_results}))\n'
)


def cmd_run(args: argparse.Namespace) -> None:
    if "all" in args.targets and len(args.targets) > 1:
        sys.stderr.write("error: 'all' cannot be combined with explicit cell ids\n")
        sys.exit(2)

    is_all = len(args.targets) == 1 and args.targets[0] == "all"
    stream = bool(args.stream) and not args.json

    if not stream:
        # atomic batch mode (existing behavior, preferred for --json)
        targets_repr = "'__ALL__'" if is_all else repr(list(args.targets))
        body = _run_body(targets_repr)
        started_at = time.monotonic()
        data = _exec_json(body, _transport_args(args), json_errors=args.json)
        elapsed_seconds = time.monotonic() - started_at
        data["elapsed_seconds"] = elapsed_seconds
        ran = data.get("ran", [])
        results = data.get("results", {})
        if args.json:
            print(json.dumps(data, indent=2, ensure_ascii=False))
            return
        err_count = _render_post_results(results)
        print(f"\nran {len(ran)} cell(s), {err_count} with errors in {_format_elapsed(elapsed_seconds)}")
        return

    # streaming mode: resolve target list, then run one cell at a time,
    # printing each cell's status as soon as it completes.
    if is_all:
        resolved = _exec_json(_RESOLVE_ALL_BODY, _transport_args(args), json_errors=False)
        targets = resolved.get("ids", [])
    else:
        targets = list(args.targets)

    total = len(targets)
    err_count = 0
    for i, cid in enumerate(targets, 1):
        body = _RUN_ONE_BODY_TEMPLATE.replace("__CID__", repr(cid))
        sys.stdout.write(f"  [{i}/{total}] running {cid} ... ")
        sys.stdout.flush()
        started_at = time.monotonic()
        data = _exec_json(body, _transport_args(args), json_errors=False)
        elapsed = _format_elapsed(time.monotonic() - started_at)
        results = data.get("results", {})
        r = results.get(cid, {})
        errs = r.get("errors") or []
        status = r.get("status", "?")
        if errs:
            err_count += 1
            sys.stdout.write(f"x {status} in {elapsed}\n")
            for e in errs:
                for line in e.splitlines():
                    sys.stdout.write(f"      ! {line}\n")
        else:
            sys.stdout.write(f"· {status} in {elapsed}\n")
    print(f"\nran {total} cell(s), {err_count} with errors")


