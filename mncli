# Snippet that assumes `_targets` (list[str]) is defined in scope and
# populates `_post_results` with each target's post-run status/errors.
_POST_RUN_SNIPPET = (
    "_post_results = {}\n"
    "async with _mncli_cm.get_context() as _ctx:\n"
    "    for _c in _ctx.cells:\n"
    "        if _c.id in _targets:\n"
    "            _errs = []\n"
    "            try:\n"
    "                for _e in (_c.errors or []):\n"
    "                    _errs.append(str(_e))\n"
    "            except Exception:\n"
    "                pass\n"
    '            _post_results[_c.id] = {"status": str(_c.status), "errors": _errs}\n'
)


def _render_post_results(results: dict) -> int:
    err_count = 0
    for cid, r in results.items():
        errs = r.get("errors") or []
        if errs:
            err_count += 1
        marker = "x" if errs else "·"
        print(f"  {marker} {cid}  {r.get('status', '?')}")
        for e in errs:
            for line in e.splitlines():
                print(f"      ! {line}")
    return err_count


def cmd_create(args: argparse.Namespace) -> None:
    code = _read_code(args.code, args.source)
    run_after = bool(args.run)
    tag = args.tag
    if tag is not None:
        if not tag or "\n" in tag or "\r" in tag:
            sys.stderr.write("error: --tag must be a non-empty single-line value\n")
            sys.exit(2)
        marker = f"# mncli-tag: {tag}"
        if not _has_exact_tag_marker(code, marker):
            code = marker + "\n" + code
    b64 = _encode(code)
    marker_repr = repr(f"# mncli-tag: {tag}") if tag is not None else "None"
    body = (
        "import base64 as _mncli_b64\n"
        f'_src = _mncli_b64.b64decode("{b64}").decode("utf-8")\n'
        f"_marker = {marker_repr}\n"
        "async with _mncli_cm.get_context() as _ctx:\n"
        "    _existing = None\n"
        "    if _marker is not None:\n"
        "        for _c in _ctx.cells:\n"
        '            if _c.code and _c.code.split("\\n", 1)[0] == _marker:\n'
        "                _existing = _c.id\n"
        "                break\n"
        "    if _existing is not None:\n"
        "        _ctx.edit_cell(_existing, _src)\n"
        "        _cell_id = _existing\n"
        '        _action = "replaced"\n'
        "    else:\n"
        "        _cell = _ctx.create_cell(_src)\n"
        '        _cell_id = _cell.id if hasattr(_cell, "id") else str(_cell)\n'
        '        _action = "created"\n'
    )
    if run_after:
        body += (
            "    _ctx.run_cell(_cell_id)\n"
            "_targets = [_cell_id]\n"
            + _POST_RUN_SNIPPET
            + '_result = {"ok": True, "id": _cell_id, "action": _action, "ran": True, "results": _post_results}\n'
        )
    else:
        body += '_result = {"ok": True, "id": _cell_id, "action": _action, "ran": False}\n'
    body += "print(_mncli_json.dumps(_result))\n"

    started_at = time.monotonic()
    data = _exec_json(body, _transport_args(args), json_errors=args.json)
    elapsed_seconds = time.monotonic() - started_at
    data["elapsed_seconds"] = elapsed_seconds
    if args.json:
        print(json.dumps(data, ensure_ascii=False))
        return
    action = data.get("action", "created")
    verb = "replaced" if action == "replaced" else "created"
    print(f"{verb} {data['id']}" + (f" (ran in {_format_elapsed(elapsed_seconds)})" if run_after else ""))
    if run_after:
        _render_post_results(data.get("results", {}))


