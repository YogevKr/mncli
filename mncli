def cmd_exec(args: argparse.Namespace) -> None:
    code = _read_code(args.code, args.source)
    stdout, stderr, rc = _run_kernel(code, _transport_args(args))
    if _is_transport_failure(stderr):
        if args.json:
            print(json.dumps(_transport_failure_payload(stderr, stdout=stdout, exit_code=rc or 1), ensure_ascii=False))
            sys.exit(rc or 1)
        _print_transport_hint(stderr)
        sys.exit(1)
    if args.json:
        payload = {
            "ok": rc == 0,
            "exit_code": rc,
            "stdout": _strip_marimo_render(stdout),
            "stderr": stderr,
        }
        print(json.dumps(payload, ensure_ascii=False))
        sys.exit(0 if rc == 0 else rc)
    if stdout:
        sys.stdout.write(stdout)
        if not stdout.endswith("\n"):
            sys.stdout.write("\n")
    if stderr:
        sys.stderr.write(stderr)
    sys.exit(rc)


def cmd_notes(args: argparse.Namespace) -> None:
    sys.stdout.write(AGENT_NOTES)
    if not AGENT_NOTES.endswith("\n"):
        sys.stdout.write("\n")


# --- main -------------------------------------------------------------------


def _add_code_input(sp: argparse.ArgumentParser) -> None:
    sp.add_argument("source", nargs="?", help="code file path, '@file', or '-' for stdin; prefer this for multiline code")
    sp.add_argument("--code", help="inline one-liner code (alternative to source)")


def _common_parser() -> argparse.ArgumentParser:
    """Transport flags accepted by kernel-attaching subcommands."""
    cp = argparse.ArgumentParser(add_help=False)
    cp.add_argument("--json", action="store_true", help="emit JSON output where applicable")
    cp.add_argument("--port", help="marimo server port; pass the port returned by `mncli start --json`")
    cp.add_argument("--url", help="marimo server URL (skip discovery)")
    cp.add_argument("--session", help="session id")
    cp.add_argument("--token", help="auth token (or set MARIMO_TOKEN)")
    return cp


def _start_common_parser() -> argparse.ArgumentParser:
    cp = argparse.ArgumentParser(add_help=False)
    cp.add_argument("--json", action="store_true", help="emit JSON output")
    cp.add_argument("--port", help="marimo server port")
    return cp


MAIN_HELP_EPILOG = """\
Agent authoring quick path:
  1. Start once:       mncli start notebook.py --json
  2. Capture port:     use payload.server.port on every later command
  3. Survey cells:     mncli status --port PORT --json
  4. Add cells:        mncli create --port PORT --tag name --run -
  5. Probe state:      mncli exec --port PORT --json -
  6. Final check:      mncli status --port PORT --errors-only --json

Rules for agents:
  - Do not use --headless when you need status/create/edit/exec now.
  - --headless starts a server only; a browser session must open before cell commands work.
  - Use mncli start notebook.py --wait-session --json when a cell command must work immediately.
  - Prefer stdin or a temp file for multiline code; reserve --code for one-liners.
  - Prefer mncli exec --json for notebook-state validation; do not assume bare python exists.
  - Keep outputs small: do not render all images/base64 blobs at once; use file paths plus a selector or pagination.
  - If multiple instances are found, do not start another server; choose a port from `mncli servers --json`.
"""


AGENT_NOTES = """\
AGENT NOTES
===========

Verb cheatsheet
---------------
  servers                        list auto-discoverable marimo servers
  start [notebook.py]            start marimo in the background
  start notebook.py --wait-session
                                 wait until status/create/edit/exec can attach
  start notebook.py --headless   start without opening a browser
  status                         list cells with status and errors
  status --errors-only           only show cells currently in error
  show <id>                      print full cell source (pipe with --code-only)
  create <src> [--run]           append a new cell
  create <src> --tag NAME --run  idempotent: replaces a cell tagged NAME
  edit <id> <src> [--run]        replace a cell's code
  run <id> [<id>...] | run all   run cell(s), returns post-run status
  run all --stream               per-cell progress while running
  delete <id> [<id>...]          delete one or more cells (idempotent)
  delete <id> --dry-run          preview without deleting
  install <pkg> [<pkg>...]       install packages into the kernel
  exec <src>                     scratch-exec Python (streaming stdout/stderr)
  exec <src> --json              structured {stdout, stderr, exit_code}
  notes                          this document

Typical workflow
----------------
  1. `mncli servers`                     — check whether a local server exists
  2. `mncli start notebook.py --json`    — start/reuse server and capture the port
  3. `mncli status --port PORT`          — survey existing cells first
  4. `mncli show <id>`                   — read a cell's full code when a preview isn't enough
  5. `mncli install pandas altair`       — add deps via the kernel, never pip/uv
  6. `mncli create --port PORT <file> --tag foo --run`
                                         — build up the notebook with idempotent tagged cells
  7. `mncli exec --port PORT --json -`   — ad-hoc inspection of notebook state
  8. `mncli edit --port PORT <id> <file> --run`
                                         — replace a cell in place when you know its id
  9. `mncli status --port PORT --errors-only`
                                         — check for regressions after a change

Caveats baked into marimo's reactive model
------------------------------------------

  Unique variable names across cells
    Every top-level name must be defined in EXACTLY ONE cell. Creating a
    second cell that defines `rows`, `df`, `tmp`, etc. will fail with:
        RuntimeError: Multiply-defined names: 'rows' is already defined in cell X
    Workarounds (pick one per helper cell):
      - Prefix locals with underscore:   `_tmp = ...`, `_rows = [...]`
      - Wrap in a function:
            def _build():
                tmp = ...
                return tmp
            result = _build()
      - `edit` the existing cell instead of `create`-ing a new one.

  Scratch exec is stateless
    `mncli exec` runs in a fresh scratchpad every time. Variables defined
    by one `exec` call are gone in the next. BUT: variables defined by
    NOTEBOOK CELLS are fully visible in every `exec` call. Put state in
    cells; use `exec` for probes, prints, and type/shape checks.

  exec final-expression render leaks into stdout (plain mode only)
    If your exec snippet's last expression returns a non-None value,
    marimo renders it and the rendered HTML (e.g. `<pre class='text-xs'>5</pre>`)
    ends up mixed into stdout. Mitigations:
      - End exec snippets with `print(...)` or an explicit `None`.
      - Or use `exec --json`, which strips the `<pre class='text-xs'>...`
        wrapper from the `stdout` field automatically.

  Cells don't auto-run on create/edit
    `create` and `edit` are structural changes — they queue the cell but
    don't execute it. Pass `--run`, or follow up with `mncli run <id>`.

  Idempotency rules
    - `create` without `--tag` is NOT idempotent: retries create duplicates.
      Use `--tag NAME` to make it idempotent — the first run creates a cell
      with a `# mncli-tag: NAME` marker prepended; subsequent runs with the
      same tag replace that cell in place.
    - `edit`, `run`, `install`, `delete` are all idempotent by construction.
    - `delete` returns status "not_found" (exit 0) when the id is already
      gone — safe to retry after a timeout.

  Start reuses matching notebooks
    `mncli start notebook.py` records the started notebook path and reuses a
    live matching server on the next call. Pass `--force-new` to intentionally
    create a second server. If you pass an occupied --port for another server,
    start exits before spawning a doomed duplicate.

  Install via `mncli install`, never pip/uv
    The kernel has its own package manager. `pip install` or `uv add`
    will bypass it and may require a kernel restart.

  Keep rendered outputs bounded
    Marimo rejects very large outputs. For media review notebooks, do not
    inline all images as base64 or render every row/card at once. Write media
    to local files, reference those paths in HTML, and render one item/page at
    a time with a selector, table pagination, or limit.

  Do not write to the .py file directly
    The kernel owns the notebook file while the session is open. Editing
    it from outside (Write, sed, manual edits) will confuse marimo.
    Always go through `create` / `edit`.

Finding and fixing errors
-------------------------
  - After `run`, `create --run`, or `edit --run`, the response already
    includes post-run status per cell — check `results[cid].errors`.
  - `mncli status --errors-only` lists only cells currently in error.
    Equivalent JSON query: `mncli status --json | jq '.[] | select(.has_error)'`.
  - Error messages are plain text — no HTML-wrapped tracebacks. If you
    need more detail, reproduce in `mncli exec` which streams stdout and
    stderr raw.
  - For long runs, `mncli run all --stream` prints per-cell progress as
    each cell completes — you can watch for the first `x` marker and
    cancel early instead of waiting for the whole notebook.

Input conventions
-----------------
  create / edit / exec accept code from any of:
    --code 'x = 1'            inline
    /path/to/cell.py          file path (also works with @/path)
    -                         explicit stdin
    (no arg, piped stdin)     implicit stdin from pipe

  For multi-line cell code, prefer writing to a temp file first rather
  than wrestling with shell quoting — e.g.:
      cat > /tmp/cell.py <<'EOF'
      import pandas as pd
      df = pd.read_csv("/tmp/data.csv")
      mo.ui.table(df.head())
      EOF
      mncli create --port PORT /tmp/cell.py --tag load-data --run

Transport
---------
  mncli is a thin Python wrapper over the marimo kernel HTTP API. Under
  the hood it shells out to the skill's execute-code.sh. Override via:
      MNCLI_EXECUTE_SCRIPT=/path/to/execute-code.sh

  `mncli start [notebook.py]` starts a marimo edit server in the background,
  writes logs beside the notebook by default, and uses --no-token so the
  session is auto-discoverable. It checks briefly for immediate startup
  failure, waits for marimo's registry entry, reports whether an active
  notebook session exists, and prints the log tail when startup fails. Pass
  `--wait-session` to exit nonzero unless exactly one session is ready for
  status/create/edit/exec. A headless server can be registered with zero active
  sessions; open the registered URL before running status/create/edit/exec. It
  uses pixi for pixi projects, uv for uv projects, and outside a project it prefers:
      uvx marimo@latest edit notebook.py --no-token --sandbox

  `mncli servers` lists the local marimo registry and removes stale entries
  by default, matching marimo-pair's discover-before-start workflow.

  Connection flags are passed through to the transport layer: --port, --url,
  --session, --token (or MARIMO_TOKEN). `start` accepts --port only.

  Transport failures produce a targeted hint: "no instances found" points
  you at `uvx marimo edit`, "failed to connect" points at the URL, etc.
"""


def _examples_epilog(lines: list[str]) -> str:
    return "Examples:\n" + "\n".join("  " + line for line in lines)


def _subparser(
    sub: "argparse._SubParsersAction",
    common: argparse.ArgumentParser,
    name: str,
    *,
    help: str,
    examples: list[str],
) -> argparse.ArgumentParser:
    return sub.add_parser(
        name,
        help=help,
        parents=[common],
        epilog=_examples_epilog(examples),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )


def build_parser() -> argparse.ArgumentParser:
    common = _common_parser()
    start_common = _start_common_parser()
    p = argparse.ArgumentParser(
        prog="mncli",
        description=(
            "CLI for driving a running marimo notebook from an agent or script. "
            "Exposes stable verbs with clean JSON output and no shell-escaping "
            "headaches."
        ),
        epilog=MAIN_HELP_EPILOG,
        formatter_class=argparse.RawDescriptionHelpFormatter,
        parents=[common],
    )
    p.add_argument("--version", action="version", version=f"mncli {__version__}")
    sub = p.add_subparsers(dest="cmd", required=True)

    sp = _subparser(sub, start_common, "servers",
        help="list auto-discoverable local marimo servers",
        examples=[
            "mncli servers",
            "mncli servers --json",
            "mncli servers --port 2718",
        ],
    )
    sp.add_argument("--no-cleanup", action="store_true",
                    help="do not remove stale registry entries for dead processes")
    sp.set_defaults(func=cmd_servers)

    sp = _subparser(sub, start_common, "start",
        help="start a marimo notebook server in the background",
        examples=[
            "mncli start notebook.py --json                  # authoring: capture returned port",
            "mncli start notebook.py --wait-session --json   # wait until cell commands can attach",
            "mncli start analysis.py --port 2718 --json",
            "mncli start analysis.py --headless --port 2718  # server only; open URL before cell commands",
            "mncli start analysis.py --force-new             # bypass matching-notebook reuse",
            "mncli start analysis.py --runner uv --no-sandbox",
            "mncli start analysis.py --dry-run",
        ],
    )
    sp.add_argument("notebook", nargs="?", default="notebook.py",
                    help="notebook path to open or create (default: notebook.py)")
    sp.add_argument("--runner", choices=["auto", "uvx", "uv", "pixi", "marimo"], default="auto",
                    help="how to invoke marimo (default: auto)")
    sp.add_argument("--headless", action="store_true",
                    help="server only: no active session until the notebook is opened in a browser")
    sp.add_argument("--wait-session", action="store_true",
                    help="wait for exactly one active notebook session; exits nonzero on timeout")
    sp.add_argument("--session-timeout-seconds", type=float, default=15.0,
                    help="seconds to wait with --wait-session (default: 15)")
    sp.add_argument("--force-new", action="store_true",
                    help="start a new server even when a matching notebook server is already running")
    sp.add_argument("--no-reuse", dest="reuse", action="store_false", default=True,
                    help="do not reuse a matching notebook server")
    sp.add_argument("--mcp", action="store_true",
                    help="start marimo with its MCP server enabled")
    sp.add_argument("--log",
                    help="log file path (default: <notebook>.marimo.log)")
    sp.add_argument("--dry-run", action="store_true",
                    help="print the command without starting marimo")
    sp.add_argument("--startup-check-seconds", type=float, default=0.25,
                    help="seconds to wait for immediate startup failure (default: 0.25)")
    sp.add_argument("--registration-timeout-seconds", type=float, default=15.0,
                    help="seconds to wait for marimo server registry entry (default: 15)")
    sandbox = sp.add_mutually_exclusive_group()
    sandbox.add_argument("--sandbox", dest="sandbox", action="store_true",
                         default=None,
                         help="force marimo sandbox mode")
    sandbox.add_argument("--no-sandbox", dest="sandbox", action="store_false",
                         help="disable marimo sandbox mode")
    sp.set_defaults(func=cmd_start)

    sp = _subparser(sub, common, "status",
        help="list cells with status and errors",
        examples=[
            "mncli status --port 2718",
            "mncli status --errors-only        # only cells currently in error",
            "mncli status --port 2718 --json",
            "mncli status --port 2718 --errors-only --json",
        ],
    )
    sp.add_argument("--errors-only", action="store_true",
                    help="only show cells that currently have errors")
    sp.set_defaults(func=cmd_status)

    sp = _subparser(sub, common, "show",
        help="print the full code of a cell",
        examples=[
            "mncli show PotT",
            "mncli show PotT --code-only > /tmp/cell.py",
            "mncli show PotT --json",
        ],
    )
    sp.add_argument("id", help="cell id")
    sp.add_argument("--code-only", action="store_true",
                    help="print only the cell source, no header")
    sp.set_defaults(func=cmd_show)

    sp = _subparser(sub, common, "create",
        help="create a new cell (append to notebook); idempotent with --tag",
        examples=[
            "mncli create --port 2718 --tag imports --run - < /tmp/cell.py",
            "printf 'x = 42\\n' | mncli create --port 2718 --tag answer --run -",
            "mncli create --port 2718 /tmp/cell.py --tag my-chart --run   # rerun replaces in place",
            "mncli create --port 2718 --code 'x = 42' --tag answer --run  # one-liner only",
        ],
    )
    _add_code_input(sp)
    sp.add_argument("--run", action="store_true", help="run the new cell after creating")
    sp.add_argument("--tag", metavar="NAME",
                    help="make this create idempotent: if a cell already starts with "
                         "`# mncli-tag: NAME` it is replaced; otherwise a new cell is "
                         "created with that marker prepended")
    sp.set_defaults(func=cmd_create)

    sp = _subparser(sub, common, "edit",
        help="replace an existing cell's code",
        examples=[
            "mncli edit PotT --code 'x = 100' --run",
            "mncli edit PotT /tmp/updated.py --run",
            "cat new_code.py | mncli edit PotT",
        ],
    )
    sp.add_argument("id", help="cell id (see `mncli status`)")
    _add_code_input(sp)
    sp.add_argument("--run", action="store_true", help="run the cell after editing")
    sp.set_defaults(func=cmd_edit)

    sp = _subparser(sub, common, "run",
        help="run one or more cells (or 'all')",
        examples=[
            "mncli run PotT",
            "mncli run PotT AbCd ZxYw",
            "mncli run all",
            "mncli run all --stream           # per-cell progress as they complete",
            "mncli run all --json             # atomic batch, full post-run status per cell",
        ],
    )
    sp.add_argument("targets", nargs="+", help="cell id(s) or 'all'")
    sp.add_argument("--stream", action="store_true",
                    help="run cells one at a time and print progress as each completes "
                         "(slower due to per-cell HTTP overhead; ignored with --json)")
    sp.set_defaults(func=cmd_run)

    sp = _subparser(sub, common, "delete",
        help="delete one or more cells (idempotent — no error if already gone)",
        examples=[
            "mncli delete PotT",
            "mncli delete PotT AbCd ZxYw          # multiple ids in one call",
            "mncli delete PotT --dry-run          # preview without deleting",
        ],
    )
    sp.add_argument("ids", nargs="+", help="cell id(s) to delete")
    sp.add_argument("--dry-run", action="store_true",
                    help="show what would be deleted without deleting")
    sp.set_defaults(func=cmd_delete)

    sp = _subparser(sub, common, "install",
        help="install packages into the kernel",
        examples=[
            "mncli install pandas",
            "mncli install pandas altair numpy",
        ],
    )
    sp.add_argument("packages", nargs="+")
    sp.set_defaults(func=cmd_install)

    sp = _subparser(sub, common, "exec",
        help="scratch-exec Python in the kernel (sees notebook state, no persistence)",
        examples=[
            "mncli exec --port 2718 --json - < /tmp/probe.py",
            "echo 'print(plates.shape)' | mncli exec --port 2718 --json -",
            "mncli exec --port 2718 --code 'print(df.describe())' --json   # one-liner probe",
            "mncli exec --port 2718 --code 'print(dir(ctx))'    # explore code_mode API",
        ],
    )
    _add_code_input(sp)
    sp.set_defaults(func=cmd_exec)

    sp = _subparser(sub, common, "notes",
        help="print agent-focused gotchas and conventions",
        examples=[
            "mncli notes",
            "mncli notes | less",
        ],
    )
    sp.set_defaults(func=cmd_notes)

    return p


def main() -> None:
    args = build_parser().parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
